# OS/editor noise
.DS_Store

# Local env/temp artifacts
*.log
.env
.env.*
.tmp/
tmp/
dist/
out/
coverage/

# Build artifacts (keep source Dockerfile for CI/release builds)
build/*
!build/docker/
!build/docker/Dockerfile.go-binary

# Generated evidence artifacts (not source code)
provenance/promotion/*
!provenance/promotion/.gitkeep
provenance/c0-cleanup/*
!provenance/c0-cleanup/.gitkeep
provenance/release-image-digests/*
!provenance/release-image-digests/.gitkeep
provenance/release-images-lockfile-sync/*
!provenance/release-images-lockfile-sync/.gitkeep
provenance/releases/*
!provenance/releases/.gitkeep
provenance/aimxs/*.json
provenance/aimxs/*.sha256
provenance/aimxs/*.vars
